<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="main">

    <!-- =========================================================
         ResultMap 정의
         ========================================================= -->

    <!-- 대회(Contest) ResultMap -->
    <resultMap id="ContestResultMap" type="com.unibridge.app.main.dto.MainDTO$ContestDTO">
        <id     property="contestNumber" column="contest_number" />
        <result property="title"         column="title"          />
        <result property="detail"        column="detail"         />
        <result property="startDate"     column="start_date"     />
        <result property="endDate"       column="end_date"       />
        <result property="hostCompany"   column="host_company"   />
        <result property="techStack"     column="tech_stack"     />
        <result property="status"        column="status"         />
    </resultMap>

    <!-- 추천 멘토 카드 ResultMap (UB_MENTORING + UB_MEMBER + UB_SUBJECT 조인) -->
    <resultMap id="MentorCardResultMap" type="com.unibridge.app.main.dto.MainDTO$MentorCardDTO">
        <id     property="internalId"      column="internal_id"      />
        <result property="mentorNumber"    column="mentor_number"     />
        <result property="mentoringTitle"  column="mentoring_title"   />
        <result property="mentoringGoal"   column="mentoring_goal"    />
        <result property="mentoringDetail" column="mentoring_detail"  />
        <result property="mentoringFile"   column="mentoring_file"    />
        <result property="subjectNumber"   column="subject_number"    />
        <result property="subjectName"     column="subject_name"      />
        <result property="memberNickname"  column="member_nickname"   />
        <result property="memberProfile"   column="member_file_number"    />
    </resultMap>

    <!-- =========================================================
         1. 진행중인 대회 목록 조회
            - UB_CONTEST 테이블에서 status 컬럼 기준 진행중 항목 조회
            - 종료일(end_date) 기준 오름차순 정렬 (마감 임박순)
            - ROWNUM 제한으로 최대 10건만 조회 (슬라이더에 표시)
         ========================================================= -->
    <select id="getContestList" resultMap="ContestResultMap">
        SELECT *
        FROM (
            SELECT
                contest_number,
                title,
                detail,
                start_date,
                end_date,
                host_company,
                tech_stack,
                status
            FROM UB_CONTEST
            WHERE status = '진행중'
            ORDER BY end_date ASC
        )
        <![CDATA[
        WHERE ROWNUM <= 10
        ]]>
    </select>

    <!-- =========================================================
         2. 추천 멘토 카드 목록 조회
            - UB_MENTORING + UB_MEMBER + UB_SUBJECT 조인
            - 최신 등록순(CREATED_AT DESC) 상위 7건
         ========================================================= -->
    <select id="getMentorCardList" resultMap="MentorCardResultMap">
        SELECT *
        FROM (
            SELECT
                m.INTERNAL_ID      AS internal_id,
                m.MENTOR_NUMBER    AS mentor_number,
                m.MENTORING_TITLE  AS mentoring_title,
                m.MENTORING_GOAL   AS mentoring_goal,
                m.MENTORING_DETAIL AS mentoring_detail,
                m.FILE_NUMBER      AS mentoring_file,
                m.SUBJECT_NUMBER   AS subject_number,
                s.subject_name     AS subject_name,
                mb.member_nickname AS member_nickname,
                mb.file_number     AS member_file_number
            FROM UB_MENTORING m
            JOIN UB_MEMBER  mb ON m.MENTOR_NUMBER  = mb.member_number
            JOIN UB_SUBJECT s  ON m.SUBJECT_NUMBER = s.subject_number
            ORDER BY m.CREATED_AT DESC
        )
        <![CDATA[
    	WHERE ROWNUM <= 7
    	]]>
    </select>

</mapper>
